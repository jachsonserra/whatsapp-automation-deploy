{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.zip",
      "use": "@vercel/static"
    },
    {
      "src": "*.{jpg,mp4}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/whatsapp-automation-landing.html"
    }
  ],
  "headers": [
    {
      "source": "/whatsapp-automation-pack.zip",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        },
        {
          "key": "Content-Type",
          "value": "application/zip"
        }
      ]
    }
  ]
}